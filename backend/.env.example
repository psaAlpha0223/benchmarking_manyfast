ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=32000
MAX_TOKENS_SUMMARY=1024
MAX_FILE_SIZE_MB=200
MAX_TOTAL_FILE_SIZE_MB=1024
ALLOWED_ORIGINS=http://localhost:3000
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...
ENV=development

# MVP 배포 단계에서 와이어프레임 생성을 끄려면 false로 설정 (서버리스 타임아웃 회피, 기능 코드는 유지)
ENABLE_WIREFRAME=true

# 직접 Postgres 연결 (마이그레이션 실행용, Session pooler)
SUPABASE_DB_HOST=aws-0-xxxx.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.xxxx
SUPABASE_DB_PASSWORD=
