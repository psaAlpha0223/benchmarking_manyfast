ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=32000
MAX_TOKENS_SUMMARY=4096
MAX_FILE_SIZE_MB=200
MAX_TOTAL_FILE_SIZE_MB=1024
ALLOWED_ORIGINS=http://localhost:3000
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...
ENV=development

# 확정된 요청 + 생성된 PRD를 적재할 노션 협업 DB (기존 행은 절대 건드리지 않고 새 행만 추가)
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# 직접 Postgres 연결 (마이그레이션 실행용, Session pooler)
SUPABASE_DB_HOST=aws-0-xxxx.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.xxxx
SUPABASE_DB_PASSWORD=
